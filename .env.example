# ── Auth (next-auth) ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=your-random-secret-here
AUTH_URL=https://yourdomain.com

# ── Admin credentials ─────────────────────────────────────────────────────────
ADMIN_USERNAME=Tahsin
ADMIN_PASSWORD=your-secure-password-here

# ── AI APIs ───────────────────────────────────────────────────────────────────
# Anthropic (Claude) — platform.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — platform.openai.com
OPENAI_API_KEY=sk-proj-...

# ── Google ────────────────────────────────────────────────────────────────────
# Maps API — enable Places API + Distance Matrix API in Google Cloud Console
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Cloud Document AI — for receipt OCR
GOOGLE_CLOUD_PROJECT_ID=your-project-id
GOOGLE_CLOUD_LOCATION=us
GOOGLE_DOCUMENTAI_PROCESSOR_ID=your-processor-id
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# OAuth (add when deploying to a live domain)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

